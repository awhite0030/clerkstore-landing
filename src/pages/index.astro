---
import '../styles/global.css';

const products = [
  { name: 'ChatGPT Plus', desc: 'Доступ к GPT-5.5, приоритетный доступ, плагины, Code Interpreter', price: 'от 1 200 ₽', color: '#10a37f', link: 'https://t.me/clerkstore_bot', icon: 'chat' },
  { name: 'Google AI PRO', desc: 'Gemini Pro 3.1, 1M контекст, Google Workspace интеграция', price: 'от 1 600 ₽', color: '#4285f4', link: 'https://t.me/clerkstore_bot', icon: 'search' },
  { name: 'Cursor Pro', desc: 'AI-powered IDE, GPT-5.5 + Claude, автодополнение кода', price: 'от 1 600 ₽', color: '#6ee7b7', link: 'https://t.me/clerkstore_bot', icon: 'code' },
  { name: 'API ключ ИИ', desc: 'Доступ к GPT-5.5, Claude Opus 4.8 через API', price: 'от 10 ₽', color: '#f59e0b', link: 'https://t.me/clerkstore_bot', icon: 'key' },
  { name: 'Leonardo AI', desc: 'Генерация изображений, 8000 кредитов, все модели', price: 'от 400 ₽', color: '#ec4899', link: 'https://t.me/clerkstore_bot', icon: 'image' }
];

const steps = [
  { num: 1, title: 'Выберите сервис', desc: 'Откройте каталог и выберите нужную подписку' },
  { num: 2, title: 'Перейдите в бота', desc: 'Нажмите «Купить» — вас перенаправит в Telegram-бота' },
  { num: 3, title: 'Оплатите и получите доступ', desc: 'Оплатите удобным способом, доступ за 5 минут' }
];

const faqItems = [
  ['Как быстро активируется подписка?', 'Обычно в течение 5 минут после оплаты. В редких случаях — до 30 минут.'],
  ['Какие способы оплаты доступны?', 'Карта, криптовалюта (USDT, BTC), СБП, электронные кошельки — всё через Telegram-бота.'],
  ['Что если возникнут проблемы?', 'Напишите в @clerkstoresupport_bot — поддержка работает ежедневно и решает все вопросы.'],
  ['Можно ли продлить подписку?', 'Да, продление доступно за 3 дня до окончания текущей подписки через того же бота.'],
  ['Есть ли гарантия?', 'Да, если доступ не будет предоставлен — полный возврат средств.']
];

const icons = {
  chat: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  search: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  code: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  key: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>`,
  image: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`
};
---

<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ClerkStore — Подписки на ИИ-сервисы</title>
  <meta name="description" content="ChatGPT Plus, Google AI PRO, Cursor Pro, API ключи, Leonardo AI — покупка через Telegram-бота" />
  <link rel="icon" type="image/png" href="/logo.png" />
</head>
<body>

<!-- ANIMATED BACKGROUND -->
<div class="bg-effects">
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="orb orb-4"></div>
</div>

<!-- HEADER -->
<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/logo.png" alt="ClerkStore" class="logo-img" />
      <span>ClerkStore</span>
    </a>
    <nav class="nav-desktop">
      <a href="#products">Товары</a>
      <a href="#how">Как купить</a>
      <a href="#faq">FAQ</a>
      <a href="https://t.me/clerkstore_bot" target="_blank" class="btn btn-gradient btn-sm">Открыть бота</a>
    </nav>
    <button class="menu-toggle" aria-label="Меню" onclick="document.body.classList.toggle('menu-open')">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="nav-mobile">
    <a href="#products" onclick="document.body.classList.remove('menu-open')">Товары</a>
    <a href="#how" onclick="document.body.classList.remove('menu-open')">Как купить</a>
    <a href="#faq" onclick="document.body.classList.remove('menu-open')">FAQ</a>
    <a href="https://t.me/clerkstore_bot" target="_blank" onclick="document.body.classList.remove('menu-open')">Открыть бота</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow">
    <div class="hero-glow-ring hero-glow-ring-1"></div>
    <div class="hero-glow-ring hero-glow-ring-2"></div>
    <div class="hero-glow-ring hero-glow-ring-3"></div>
  </div>
  <div class="container">
    <div class="hero-inner reveal">
      <h1>Подписки на&nbsp;ИИ&#8209;сервисы через&nbsp;Telegram</h1>
      <p>ChatGPT Plus, Gemini Pro, Cursor Pro, API&#8209;ключи и&nbsp;Leonardo&nbsp;AI. Оплата любым способом, доступ за&nbsp;пять минут.</p>
      <div class="hero-actions">
        <a href="#products" class="btn btn-gradient">Выбрать подписку</a>
        <a href="https://t.me/clerkstore_bot" target="_blank" class="btn btn-glow">Открыть бота</a>
      </div>
    </div>
    <div class="hero-links reveal reveal-delay-2">
      <a href="https://t.me/clerkstore_news" target="_blank" class="hero-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Канал с новостями
      </a>
      <a href="https://t.me/clerkstoresupport_bot" target="_blank" class="hero-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Поддержка
      </a>
    </div>
  </div>
  <div class="scroll-indicator">
    <span>Scroll</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
</section>

<div class="container"><div class="section-divider"></div></div>

<!-- PRODUCTS -->
<section id="products" class="products">
  <div class="container">
    <div class="section-header reveal">
      <h2>Товары</h2>
      <p>Выберите нужный сервис и получите доступ за несколько минут</p>
    </div>
    <div class="product-grid">
      {products.map((p, i) => (
        <div class={`product-card reveal reveal-delay-${i + 1}`} style={`--card-color: ${p.color}`} data-card>
          <div class="product-card-inner">
            <div class="product-icon" style={`--card-color: ${p.color}`} set:html={icons[p.icon]}></div>
            <h3>{p.name}</h3>
            <p class="desc">{p.desc}</p>
            <div class="product-card-footer">
              <span class="product-price">{p.price}</span>
              <button class="btn btn-buy" data-product={p.name} data-price={p.price} data-link={p.link}>Купить</button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="container"><div class="section-divider"></div></div>

<!-- HOW IT WORKS -->
<section id="how" class="how">
  <div class="container">
    <div class="section-header reveal">
      <h2>Как купить</h2>
      <p>Три простых шага до доступа</p>
    </div>
    <div class="steps">
      {steps.map((s) => (
        <div class="step reveal">
          <div class="step-num">{s.num}</div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="container"><div class="section-divider"></div></div>

<!-- FAQ -->
<section id="faq" class="faq">
  <div class="container">
    <div class="section-header reveal">
      <h2>Вопросы и ответы</h2>
      <p>Всё, что нужно знать перед покупкой</p>
    </div>
    <div class="faq-list">
      {faqItems.map(([q, a]) => (
        <details class="faq-item reveal">
          <summary>{q}</summary>
          <p>{a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src="/logo.png" alt="ClerkStore" class="footer-logo" />
      <span>ClerkStore</span>
    </div>
    <div class="footer-links">
      <a href="https://t.me/clerkstore_bot" target="_blank">Telegram-бот</a>
      <a href="https://t.me/clerkstoresupport_bot" target="_blank">Поддержка</a>
      <a href="https://t.me/clerkstore_news" target="_blank">Новости</a>
    </div>
    <p class="footer-copy">&copy; {new Date().getFullYear()} ClerkStore. Все права защищены.</p>
  </div>
</footer>

<!-- BUY MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <button class="modal-close" onclick="document.getElementById('modal').classList.remove('modal-open')">&times;</button>
    <h3 id="modal-title">Оформление заказа</h3>
    <p id="modal-desc"></p>
    <div class="modal-actions">
      <a id="modal-link" href="#" target="_blank" class="btn btn-gradient modal-btn">Перейти в бота</a>
      <button class="btn btn-text modal-btn" onclick="document.getElementById('modal').classList.remove('modal-open')">Закрыть</button>
    </div>
  </div>
</div>

<script>
  // IntersectionObserver for scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Card glow + 3D tilt on mouse move
  document.querySelectorAll('[data-card]').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -5;
      const rotateY = ((x - centerX) / centerX) * 5;

      card.style.setProperty('--glow-x', x + 'px');
      card.style.setProperty('--glow-y', y + 'px');
      card.style.setProperty('--rotate-x', rotateX + 'deg');
      card.style.setProperty('--rotate-y', rotateY + 'deg');
    });

    card.addEventListener('mouseleave', () => {
      card.style.setProperty('--rotate-x', '0deg');
      card.style.setProperty('--rotate-y', '0deg');
    });
  });

  // Modal logic
  document.querySelectorAll('.btn-buy').forEach(btn => {
    btn.addEventListener('click', () => {
      const name = btn.dataset.product;
      const price = btn.dataset.price;
      const link = btn.dataset.link;
      document.getElementById('modal-title').textContent = name;
      document.getElementById('modal-desc').textContent = `Цена: ${price}. Перейдите в Telegram-бот для оформления.`;
      document.getElementById('modal-link').href = link;
      document.getElementById('modal').classList.add('modal-open');
    });
  });

  document.getElementById('modal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
      e.currentTarget.classList.remove('modal-open');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('modal').classList.remove('modal-open');
    }
  });
</script>

</body>
</html>
